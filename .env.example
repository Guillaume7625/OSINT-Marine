# Copy to infra/.env and adjust values.
# Codespaces: set ANTHROPIC_API_KEY as a Codespaces secret (recommended).
# The devcontainer post-create step can sync it into infra/.env and .env.
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
AUTO_MIGRATE_ON_STARTUP=true

POSTGRES_USER=assistant
POSTGRES_PASSWORD=assistant
POSTGRES_DB=assistant
DATABASE_URL=postgresql+psycopg://assistant:assistant@localhost:5432/assistant
REDIS_URL=redis://localhost:6379/0

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_COMPLEX=claude-opus-4-6
ANTHROPIC_TIMEOUT_SECONDS=60
ANTHROPIC_MAX_TOKENS=2048

DEFAULT_PROVIDER=anthropic
DEFAULT_ROUTING_MODE=policy
DEFAULT_CONTEXT_WINDOW_MESSAGES=20
MAX_TOOL_ITERATIONS=4

BOOTSTRAP_GLOBAL_PROMPT=You are a precise and helpful assistant.
BOOTSTRAP_WORKSPACE_PROMPT=You are running in a local-first MVP workspace.

UPLOAD_ROOT=./backend_data/uploads
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
